# LLM Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Embeddings (default: openai)
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_PROVIDER=openai

# Vision LLM for complex document parsing
VISION_MODEL=claude-sonnet-4-6
VISION_PROVIDER=anthropic

# Synthesis / query LLM
SYNTHESIS_MODEL=claude-sonnet-4-6
SYNTHESIS_PROVIDER=anthropic

# Qdrant (vector store)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=harrisburg_kb

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/harrisburg_kb

# Neo4j (graph database)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Redis (for Celery background jobs)
REDIS_URL=redis://localhost:6379/0

# Observability (LangSmith)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=harrisburg-kb
LANGCHAIN_TRACING_V2=false

# Ingestion settings
DOCS_DIR=docs
MAX_CHUNK_SIZE=1500
MIN_CHUNK_SIZE=100
CHUNK_OVERLAP=100
EXTRACTION_BATCH_SIZE=8

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
